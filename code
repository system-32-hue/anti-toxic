local Players = game:GetService("Players")
local player = Players.LocalPlayer

local notificationsEnabled = true

local function Notify(message)
	if notificationsEnabled then
		warn("[Systems ANTI-CHEAT] " .. message)
	end
end

local function CheckExploit(name, kickReason)
	local obj = game:FindFirstChild(name, true)

	if obj then
		obj:Destroy()

		Notify("Exploit detected: " .. name)

		player:Kick(kickReason)
	end
end

while task.wait(1) do
	CheckExploit(
		"Dex",
		"Someone tried to run Dex."
	)

	CheckExploit(
		"IY_GUI",
		"Someone tried to run Infinite Yield."
	)
end
